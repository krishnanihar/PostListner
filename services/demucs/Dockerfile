FROM python:3.11-slim

RUN apt-get update && apt-get install -y --no-install-recommends \
    ffmpeg git && rm -rf /var/lib/apt/lists/*

WORKDIR /app
COPY requirements.txt .
RUN pip install --no-cache-dir -r requirements.txt

COPY server.py .

# Run as a non-root user. demucs caches the model under $HOME so we give the
# user a real home directory.
RUN useradd --create-home --shell /usr/sbin/nologin demucs \
    && chown -R demucs:demucs /app
USER demucs

EXPOSE 8001
CMD ["python", "server.py"]
